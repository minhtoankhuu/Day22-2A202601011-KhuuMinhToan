# ══════════════════════════════════════════════════════════════════
#  Day 22 Lab — Environment Variables Template
#  Sao chép file này thành .env và điền thông tin API keys của bạn
#  KHÔNG bao giờ commit file .env lên GitHub!
# ══════════════════════════════════════════════════════════════════

# ── LangSmith (bắt buộc cho tất cả các bước) ─────────────────────
# Lấy API key tại: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=day22-lab
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Chọn LLM Provider ─────────────────────────────────────────────
# Đổi giá trị này để chọn provider bạn muốn dùng:
#   openai | gemini | anthropic | ollama | openrouter
PROVIDER=openai

# ── OpenAI (mặc định) ─────────────────────────────────────────────
# Lấy API key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=  # để trống khi dùng OpenAI chính thức
              # điền URL nếu dùng proxy hoặc Azure OpenAI

# ── Google Gemini ─────────────────────────────────────────────────
# Lấy API key tại: https://aistudio.google.com/app/apikey
# Cài thêm: pip install langchain-google-genai
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001

# ── Anthropic ─────────────────────────────────────────────────────
# Lấy API key tại: https://console.anthropic.com/
# Cài thêm: pip install langchain-anthropic
# Lưu ý: Anthropic không có Embeddings API → cần thêm OPENAI_API_KEY để dùng embeddings
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ollama (local, miễn phí, không cần API key) ───────────────────
# Cài Ollama: https://ollama.ai
# Cài thêm: pip install langchain-ollama
# Chạy trước: ollama pull llama3.1 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── OpenRouter (truy cập nhiều model qua 1 API key) ──────────────
# Lấy API key tại: https://openrouter.ai/keys
# Xem danh sách models: https://openrouter.ai/models
# Cài thêm: pip install langchain-openai (đã có)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
